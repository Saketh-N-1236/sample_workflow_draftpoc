+
+/**
+ * Returns true when the given BCP-47 language code represents a right-to-left
+ * writing system (Arabic, Hebrew, Farsi, Urdu).
+ * The check is case-insensitive so both 'AR' and 'ar' return true.
+ */
+export function isRtlLanguage(code) {
+  if (typeof code !== 'string') return false;
+  return ['ar', 'he', 'fa', 'ur'].includes(code.toLowerCase());
+}

