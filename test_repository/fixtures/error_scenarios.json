{
  "connection_errors": {
    "mcp_server_unavailable": {
      "error_type": "ConnectionError",
      "message": "Cannot connect to MCP server 'catalog' at http://localhost:8001/sse. Make sure the server is running.",
      "retryable": true,
      "max_retries": 2
    },
    "timeout_error": {
      "error_type": "TimeoutError",
      "message": "Request timed out after 30 seconds",
      "retryable": true,
