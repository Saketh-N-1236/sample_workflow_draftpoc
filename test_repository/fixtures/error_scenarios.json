    },
    "invalid_type": {
      "error_type": "TypeError",
      "message": "Invalid type for 'limit': expected integer, got string",
      "field": "limit",
      "retryable": false
    },
    "invalid_format": {
      "error_type": "ValueError",
      "message": "Invalid collection name format: must be 3-63 alphanumeric characters",
      "field": "collection_name",
      "retryable": false
    }
  },
